# Interjector configuration. Copy to `.env` and fill in.
# All settings live here on the server; the frontend has no settings page.
# Loaded automatically by `npm run dev` and `npm start`.

# --- Server ---
PORT=8000
HOST=localhost
# Serve plain HTTP (TLS terminated by a reverse proxy). Recommended for local dev.
HTTP_ONLY=true
# For HTTPS instead, set HTTP_ONLY=false and provide a cert (see `npm run gen-cert`):
# KEY_PATH=./certs/dev.key
# CERT_PATH=./certs/dev.cert

# --- Speech recognition (Deepgram) ---
# Required for transcription. Stays on the server; never sent to the browser.
DEEPGRAM_API_KEY=
# Model (default nova-3) and language ('multi' = multilingual / code-switching).
DEEPGRAM_MODEL=nova-3
DEEPGRAM_LANGUAGE=multi
# Speaker diarization (角色识别).
DEEPGRAM_DIARIZE=false

# --- Translation ---
# Source language is also shown in the UI. Use BCP 47 tags.
TRANSLATION_SOURCE_LANGUAGE=en
TRANSLATION_TARGET_LANGUAGE=zh
# One of: free-google-translate | google-translate | bing-translate | deepl-translate | openai-translate
TRANSLATION_BACKEND=free-google-translate
# API URL/key/model/prompt depend on the backend.
# free-google-translate needs no key; openai-translate needs model + prompt.
TRANSLATION_API_URL=https://translate.google.com/translate_a/single
TRANSLATION_API_KEY=
TRANSLATION_MODEL=
TRANSLATION_PROMPT=

# --- LLM completion (optional; the per-preset "Complete" buttons) ---
# OpenAI-style URL, or a Gemini base URL for gemini-* models.
COMPLETION_API_URL=
COMPLETION_API_KEY=
COMPLETION_MODEL=
# Directory of prompt presets: one *.md file per completion panel. Files are
# shown in file-name order (use a numeric prefix like 10-, 20- to order them),
# and the label is derived from the file name (e.g. 20-background-knowledge.md
# → "Background knowledge"). The prompt text stays on the server; only the
# id/label reach the browser. Defaults to ./prompts.
COMPLETION_PROMPTS_DIR=prompts
# Fallback single prompt, used only when COMPLETION_PROMPTS_DIR has no prompts.
COMPLETION_PROMPT=
